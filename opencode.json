{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "consistency-checker": {
      "description": "设定一致性检查，输出结构化报告供润色步骤参考",
      "mode": "subagent",
      "temperature": 0.1,
      "max_tokens": 4000,
      "permission": {
        "read_file": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow",
          "grep *": "allow"
        }
      },
      "prompt": "{file:./prompts/consistency-checker.txt}"
    },
    
    "context-agent": {
      "description": "上下文搜集Agent，生成创作执行包供Step 2A直接消费",
      "mode": "subagent",
      "temperature": 0.2,
      "max_tokens": 6000,
      "permission": {
        "read_file": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow"
        }
      },
      "prompt": "{file:./prompts/context-agent.txt}"
    },
    
    "continuity-checker": {
      "description": "连贯性检查，输出结构化报告供润色步骤参考",
      "mode": "subagent",
      "temperature": 0.1,
      "max_tokens": 4000,
      "timeout": 120,
      "permission": {
        "read_file": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "{file:./prompts/continuity-checker.txt}"
    },
    
    "data-agent": {
      "description": "数据处理Agent，负责AI实体提取、场景切片、索引构建",
      "mode": "subagent",
      "temperature": 0.1,
      "max_tokens": 5000,
      "timeout": 300,
      "permission": {
        "read_file": "allow",
        "write_file": "allow",
        "edit": "allow",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow",
          "sqlite3 *": "allow"
        }
      },
      "prompt": "{file:./prompts/data-agent.txt}"
    },
    
    "high-point-checker": {
      "description": "爽点密度检查，支持迪化误解/身份掉马模式",
      "mode": "subagent",
      "temperature": 0.1,
      "max_tokens": 4000,
      "permission": {
        "read_file": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": {
          "*": "ask",
          "grep *": "allow"
        }
      },
      "prompt": "{file:./prompts/high-point-checker.txt}"
    },
    
    "ooc-checker": {
      "description": "人物OOC检查，防止角色行为与人设冲突",
      "mode": "subagent",
      "temperature": 0.1,
      "max_tokens": 4000,
      "permission": {
        "read_file": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "{file:./prompts/ooc-checker.txt}"
    },
    
    "pacing-checker": {
      "description": "Strand Weave节奏检查，防止读者疲劳",
      "mode": "subagent",
      "temperature": 0.1,
      "max_tokens": 4000,
      "permission": {
        "read_file": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow"
        }
      },
      "prompt": "{file:./prompts/pacing-checker.txt}"
    },
    
    "reader-pull-checker": {
      "description": "追读力检查器，评估钩子/微兑现/约束分层",
      "mode": "subagent",
      "temperature": 0.1,
      "max_tokens": 4500,
      "permission": {
        "read_file": "allow",
        "grep": "allow",
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow"
        }
      },
      "prompt": "{file:./prompts/reader-pull-checker.txt}"
    }
  },
  
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "python *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "ls *": "allow"
    },
    "webfetch": "deny",
    "task": "allow"
  }
}
