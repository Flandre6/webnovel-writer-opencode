{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "consistency-checker": {
      "description": "设定一致性检查，输出结构化报告供润色步骤参考",
      "mode": "subagent",
      "model": "anthropic/claude-3.5-sonnet-20241022",
      "temperature": 0.1,
      "max_tokens": 4000,
      "tools": {
        "read_file": true,
        "grep": true,
        "bash": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow",
          "grep *": "allow"
        }
      },
      "prompt": "{file:./prompts/consistency-checker.txt}"
    },
    
    "context-agent": {
      "description": "上下文搜集Agent，生成创作执行包供Step 2A直接消费",
      "mode": "subagent",
      "model": "anthropic/claude-3.5-sonnet-20241022",
      "temperature": 0.2,
      "max_tokens": 6000,
      "tools": {
        "read_file": true,
        "grep": true,
        "bash": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow"
        }
      },
      "prompt": "{file:./prompts/context-agent.txt}"
    },
    
    "continuity-checker": {
      "description": "连贯性检查，输出结构化报告供润色步骤参考",
      "mode": "subagent",
      "model": "anthropic/claude-3.5-sonnet-20241022",
      "temperature": 0.1,
      "max_tokens": 4000,
      "timeout": 120,
      "tools": {
        "read_file": true,
        "grep": true
      },
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "{file:./prompts/continuity-checker.txt}"
    },
    
    "data-agent": {
      "description": "数据处理Agent，负责AI实体提取、场景切片、索引构建",
      "mode": "subagent",
      "model": "anthropic/claude-3.5-sonnet-20241022",
      "temperature": 0.1,
      "max_tokens": 5000,
      "timeout": 300,
      "tools": {
        "read_file": true,
        "write_file": true,
        "bash": true,
        "python": true
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow",
          "sqlite3 *": "allow"
        }
      },
      "prompt": "{file:./prompts/data-agent.txt}"
    },
    
    "high-point-checker": {
      "description": "爽点密度检查，支持迪化误解/身份掉马模式",
      "mode": "subagent",
      "model": "anthropic/claude-3.5-sonnet-20241022",
      "temperature": 0.1,
      "max_tokens": 4000,
      "tools": {
        "read_file": true,
        "grep": true,
        "bash": true,
        "rag_search": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "grep *": "allow"
        }
      },
      "prompt": "{file:./prompts/high-point-checker.txt}"
    },
    
    "ooc-checker": {
      "description": "人物OOC检查，防止角色行为与人设冲突",
      "mode": "subagent",
      "model": "anthropic/claude-3.5-sonnet-20241022",
      "temperature": 0.1,
      "max_tokens": 4000,
      "tools": {
        "read_file": true,
        "grep": true
      },
      "permission": {
        "edit": "deny",
        "bash": "deny"
      },
      "prompt": "{file:./prompts/ooc-checker.txt}"
    },
    
    "pacing-checker": {
      "description": "Strand Weave节奏检查，防止读者疲劳",
      "mode": "subagent",
      "model": "anthropic/claude-3.5-sonnet-20241022",
      "temperature": 0.1,
      "max_tokens": 4000,
      "tools": {
        "read_file": true,
        "grep": true,
        "bash": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow"
        }
      },
      "prompt": "{file:./prompts/pacing-checker.txt}"
    },
    
    "reader-pull-checker": {
      "description": "追读力检查器，评估钩子/微兑现/约束分层",
      "mode": "subagent",
      "model": "anthropic/claude-3.5-sonnet-20241022",
      "temperature": 0.1,
      "max_tokens": 4500,
      "tools": {
        "read_file": true,
        "grep": true,
        "bash": true,
        "rag_search": true
      },
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow"
        }
      },
      "prompt": "{file:./prompts/reader-pull-checker.txt}"
    },
    
    "webnovel-build": {
      "description": "Webnovel写作主代理，协调所有子代理完成章节创作",
      "mode": "primary",
      "model": "anthropic/claude-3.5-sonnet-20241022",
      "temperature": 0.3,
      "color": "#4CAF50",
      "tools": {
        "read_file": true,
        "write_file": true,
        "edit": true,
        "bash": true,
        "grep": true
      },
      "permission": {
        "edit": "allow",
        "bash": {
          "*": "ask",
          "python *webnovel.py*": "allow",
          "git *": "ask"
        },
        "task": {
          "consistency-checker": "allow",
          "context-agent": "allow",
          "continuity-checker": "allow",
          "data-agent": "allow",
          "high-point-checker": "allow",
          "ooc-checker": "allow",
          "pacing-checker": "allow",
          "reader-pull-checker": "allow"
        }
      },
      "prompt": "{file:./prompts/webnovel-build.txt}"
    },
    
    "webnovel-plan": {
      "description": "Webnovel规划代理，用于分析章节大纲和制定创作计划",
      "mode": "primary",
      "model": "anthropic/claude-3.5-haiku-20241022",
      "temperature": 0.1,
      "color": "#2196F3",
      "tools": {
        "read_file": true,
        "grep": true,
        "bash": false,
        "write_file": false,
        "edit": false
      },
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "task": {
          "context-agent": "allow",
          "*": "deny"
        }
      },
      "prompt": "{file:./prompts/webnovel-plan.txt}"
    }
  },
  
  "permission": {
    "edit": "ask",
    "bash": {
      "*": "ask",
      "python *": "allow",
      "grep *": "allow",
      "cat *": "allow",
      "ls *": "allow"
    },
    "webfetch": "deny"
  },
  
  "tools": {
    "read_file": true,
    "write_file": true,
    "edit": true,
    "bash": true,
    "grep": true
  }
}